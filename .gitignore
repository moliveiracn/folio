# -----------------------------------------------
# folio .gitignore
# -----------------------------------------------

data/
*.db
*.db-shm
*.db-wal

# --- Build output ---
tmp/            # air hot-reload output
folio           # compiled binary (linux)
folio.exe       # compiled binary (windows)
dist/           # release builds

# --- Environment / secrets ---
.env
.env.*
config.yaml     # generated by folio init, contains bcrypt hash
!config.example.yaml

# --- Editor ---
.vscode/
.idea/
*.swp
*.swo
Thumbs.db

# --- OS ---
.DS_Store
desktop.ini